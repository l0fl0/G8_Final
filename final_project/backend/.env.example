# Copy this file to .env and fill in your values
# Never commit the real .env to GitHub

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=gamevault
DB_PASSWORD=yourpassword
DB_NAME=GamePlatformDB

# ── Server ────────────────────────────────────────────────────
PORT=3000

# ── JWT ───────────────────────────────────────────────────────
# Change this to a long random string before deploying
JWT_SECRET=gamevault_super_secret_jwt_key_change_in_production
